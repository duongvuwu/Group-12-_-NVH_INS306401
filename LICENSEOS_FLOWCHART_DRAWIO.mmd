flowchart LR
    %% LicenseOS workflow + ERD map for draw.io
    %% Import in draw.io: Arrange > Insert > Advanced > Mermaid

    ADMIN["Admin / Operator"]
    UI["Browser UI<br/>Dashboard, Nen tang, Luat, Kho, Cap phat, License Copilot"]
    ROUTER["public/index.php<br/>Router by page"]
    LAYOUT["core/Layout.php<br/>Shared layout, toast, modal, dark mode"]

    ADMIN --> UI --> ROUTER --> LAYOUT

    subgraph MVC["Native PHP MVC"]
        direction TB
        DASH_C["DashboardController<br/>DashboardModel"]
        ADMIN_C["PlatformAdminController<br/>PlatformAdminModel"]
        RULE_C["AllocationRuleController<br/>AllocationRuleModel"]
        INV_C["InventoryController<br/>InventoryModel"]
        ALLOC_C["LicenseAllocationController<br/>LicenseAllocationModel"]
        ASSIST_C["LicenseAssistantController<br/>LicenseAssistantService<br/>Intent Resolver + Models"]
        AUDIT_M["AuditLogModel"]
    end

    LAYOUT --> DASH_C
    LAYOUT --> ADMIN_C
    LAYOUT --> RULE_C
    LAYOUT --> INV_C
    LAYOUT --> ALLOC_C
    LAYOUT --> ASSIST_C

    subgraph MASTER["Master Data"]
        direction TB
        DEP["departments<br/>PK id<br/>UK name<br/>description"]
        USR["users<br/>PK id<br/>FK department_id<br/>UK email<br/>role"]
        SW["software_titles<br/>PK id<br/>UK name + vendor<br/>vendor"]
    end

    subgraph POLICY["Allocation Rules"]
        direction TB
        AR["allocation_rules<br/>PK id<br/>FK software_id<br/>FK department_id<br/>target_role<br/>UK software + department + role"]
    end

    subgraph INVENTORY["License Inventory"]
        direction TB
        SA["software_assets<br/>PK id<br/>FK software_id<br/>version, os_type<br/>download_url"]
        LP["license_pools<br/>PK id<br/>FK software_id<br/>total_quantity<br/>available_quantity<br/>expires_at<br/>reusable_after_revocation"]
        LK["license_keys<br/>PK id<br/>FK pool_id<br/>UK key_value<br/>is_assigned<br/>assigned_at"]
    end

    subgraph LIFECYCLE["License Lifecycle"]
        direction TB
        LA["license_allocations<br/>PK id<br/>FK user_id<br/>FK key_id<br/>start_date, end_date<br/>status Active/Expired/Revoked"]
        ACT["activation_logs<br/>PK id<br/>FK allocation_id<br/>activation_time<br/>ip_address"]
        EXP["expiry_notifications<br/>PK id<br/>FK allocation_id<br/>sent_time<br/>alert_type<br/>UK allocation + alert"]
        REV["revocation_logs<br/>PK id<br/>FK allocation_id<br/>revocation_time<br/>reason"]
    end

    subgraph REPORTING["Reporting & Audit"]
        direction TB
        STAT["usage_stats<br/>PK id<br/>FK software_id<br/>FK department_id<br/>active_count<br/>report_period<br/>UK software + department + period"]
        AUD["audit_logs<br/>PK id<br/>actor, action<br/>entity_type, entity_id<br/>context_json<br/>No physical FK"]
    end

    subgraph ASSISTANT_DATA["Assistant Conversation Data"]
        direction TB
        CONV["assistant_conversations<br/>PK id<br/>UK session_token<br/>language, metadata_json<br/>last_activity_at"]
        MSG["assistant_messages<br/>PK id<br/>FK conversation_id<br/>sender, intent, status<br/>message_text, response_json<br/>duration_ms"]
    end

    %% MVC to data ownership
    DASH_C --> DEP
    DASH_C --> USR
    DASH_C --> SW
    DASH_C --> LP
    DASH_C --> LA
    DASH_C --> AUD

    ADMIN_C --> DEP
    ADMIN_C --> USR
    ADMIN_C --> SW
    RULE_C --> AR
    INV_C --> SA
    INV_C --> LP
    INV_C --> LK
    ALLOC_C --> LA
    ALLOC_C --> ACT
    ALLOC_C --> EXP
    ALLOC_C --> REV
    ASSIST_C -.->|read-only approved intents| DEP
    ASSIST_C -.->|read-only approved intents| USR
    ASSIST_C -.->|read-only approved intents| SW
    ASSIST_C -.->|read-only approved intents| LP
    ASSIST_C -.->|read-only approved intents| LK
    ASSIST_C -.->|read-only approved intents| LA
    ASSIST_C --> CONV
    ASSIST_C --> MSG

    ADMIN_C -.->|write sensitive action| AUDIT_M
    RULE_C -.->|write sensitive action| AUDIT_M
    INV_C -.->|write sensitive action| AUDIT_M
    ALLOC_C -.->|write sensitive action| AUDIT_M
    AUDIT_M -.->|soft reference: entity_type + entity_id| AUD

    %% Physical database relationships
    DEP -->|"1:N<br/>users.department_id"| USR
    DEP -->|"1:N<br/>allocation_rules.department_id"| AR
    DEP -->|"1:N<br/>usage_stats.department_id"| STAT

    SW -->|"1:N<br/>software_assets.software_id"| SA
    SW -->|"1:N<br/>license_pools.software_id"| LP
    SW -->|"1:N<br/>allocation_rules.software_id"| AR
    SW -->|"1:N<br/>usage_stats.software_id"| STAT

    LP -->|"1:N<br/>license_keys.pool_id"| LK
    USR -->|"1:N<br/>license_allocations.user_id"| LA
    LK -->|"1:N history<br/>license_allocations.key_id"| LA

    LA -->|"1:N<br/>activation_logs.allocation_id"| ACT
    LA -->|"1:N<br/>expiry_notifications.allocation_id"| EXP
    LA -->|"1:N<br/>revocation_logs.allocation_id"| REV
    CONV -->|"1:N<br/>assistant_messages.conversation_id"| MSG

    subgraph ASSISTANT_FLOW["License Copilot Workflow"]
        direction LR
        A1["Question + language"]
        A2["CSRF + input limit + rate limit"]
        A3["Resolve allowlisted intent"]
        A4["Prepared read-only query"]
        A5["Format metric/list/action response"]
        A6["Persist redacted history"]
    end

    ASSIST_C --> A1 --> A2 --> A3 --> A4 --> A5 --> A6
    A4 -.-> DEP
    A4 -.-> USR
    A4 -.-> SW
    A4 -.-> LP
    A4 -.-> LA
    A6 -.-> CONV
    A6 -.-> MSG

    subgraph CORE_FLOW["Core Allocation Workflow"]
        direction LR
        F1["Select user + software + duration"]
        F2{"Match allocation rule?"}
        F3{"User already has active license?"}
        F4{"Available valid key?"}
        F5["BEGIN TRANSACTION"]
        F6["Lock key<br/>SELECT ... FOR UPDATE"]
        F7["Insert allocation"]
        F8["Mark key assigned"]
        F9["Sync pool availability"]
        F10["COMMIT + audit log + toast"]
        F11["Reject with error toast"]
    end

    ALLOC_C --> F1
    F1 --> F2
    F2 -->|"No"| F11
    F2 -->|"Yes"| F3
    F3 -->|"Yes"| F11
    F3 -->|"No"| F4
    F4 -->|"No"| F11
    F4 -->|"Yes"| F5 --> F6 --> F7 --> F8 --> F9 --> F10
    F6 -.->|locks| LK
    F7 -.->|creates| LA
    F8 -.->|updates| LK
    F9 -.->|updates| LP
    F10 -.->|writes| AUD

    classDef entry fill:#ecfeff,stroke:#0891b2,color:#0f172a,stroke-width:2px;
    classDef mvc fill:#eff6ff,stroke:#2563eb,color:#0f172a,stroke-width:2px;
    classDef master fill:#f0fdf4,stroke:#16a34a,color:#052e16,stroke-width:2px;
    classDef policy fill:#fefce8,stroke:#ca8a04,color:#422006,stroke-width:2px;
    classDef inventory fill:#fff7ed,stroke:#ea580c,color:#431407,stroke-width:2px;
    classDef lifecycle fill:#fdf2f8,stroke:#db2777,color:#500724,stroke-width:2px;
    classDef reporting fill:#f5f3ff,stroke:#7c3aed,color:#2e1065,stroke-width:2px;
    classDef assistant fill:#ecfdf5,stroke:#0d9488,color:#042f2e,stroke-width:2px;
    classDef decision fill:#ffffff,stroke:#0f172a,color:#0f172a,stroke-width:2px;
    classDef reject fill:#fef2f2,stroke:#e11d48,color:#7f1d1d,stroke-width:2px;

    class ADMIN,UI,ROUTER,LAYOUT entry;
    class DASH_C,ADMIN_C,RULE_C,INV_C,ALLOC_C,ASSIST_C,AUDIT_M mvc;
    class DEP,USR,SW master;
    class AR policy;
    class SA,LP,LK inventory;
    class LA,ACT,EXP,REV lifecycle;
    class STAT,AUD reporting;
    class CONV,MSG,A1,A2,A3,A4,A5,A6 assistant;
    class F2,F3,F4 decision;
    class F11 reject;
